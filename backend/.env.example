PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app

# Storage
UPLOADS_DIR=uploads
CONVERTED_DIR=converted

# Redis (For BullMQ)
# On Render, you will get a REDIS_URL like redis://red-xxxx:6379
REDIS_URL=

# File Settings
MAX_FILE_SIZE_MB=50
FILE_EXPIRY_MINUTES=30
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
