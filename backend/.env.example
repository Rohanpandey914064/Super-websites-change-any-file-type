PORT=5000
NODE_ENV=development

# Storage paths
UPLOADS_DIR=../uploads
CONVERTED_DIR=../converted

# File settings
MAX_FILE_SIZE_MB=50
FILE_EXPIRY_MINUTES=30

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
FRONTEND_URL=http://localhost:3000

# AWS S3 (optional - for production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=
